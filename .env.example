# === Core Bot Config ===
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
DATABASE_PATH=stocks.db
INITIAL_CASH=10000
DEBUG=true
LOG_DIR=logs

# === Daily Rewards ===
DAILY_MIN_REWARD=500
DAILY_MAX_REWARD=2000

# === Market ===
MARKET_UPDATE_INTERVAL=300
LEADERBOARD_UPDATE_INTERVAL=300
YFINANCE_CACHE_SECONDS=120
COMMAND_COOLDOWN=5

# === Trading ===
OPTION_PREMIUM_PCT=0.05
SHORT_MARGIN_PCT=1.5
MAX_HISTORY_RESULTS=10

# === Events ===
EVENT_PROBABILITY=0.08
DIVIDEND_PROBABILITY=0.03
SPLIT_PROBABILITY=0.01
PUMP_DUMP_PROBABILITY=0.03

# === Tournament ===
TOURNAMENT_DEFAULT_CASH=10000
TOURNAMENT_DEFAULT_DURATION_DAYS=7
TOURNAMENT_REWARD_1ST=50000
TOURNAMENT_REWARD_2ND=25000
TOURNAMENT_REWARD_3RD=10000

# === Insider Leaks ===
INSIDER_LEAK_COST=500
INSIDER_ACCURACY_PCT=0.6
INSIDER_COOLDOWN_SECONDS=3600

# === Hedge Funds ===
FUND_MAX_MEMBERS=10
FUND_MIN_CONTRIBUTION=1000

# === Margin Trading ===
MAX_LEVERAGE=3.0
MARGIN_CALL_THRESHOLD=0.25
MARGIN_CHECK_INTERVAL=60

# === Copy Trading ===
COPY_TRADE_MAX_PCT=0.10
MAX_COPY_FOLLOWERS=20

# === IPO ===
IPO_VOLATILITY_MULTIPLIER=2.0

# === Prestige ===
PRESTIGE_NET_WORTH_REQ=10000000
PRESTIGE_DAILY_BONUS=0.10

# === Market Hours ===
MARKET_HOURS_ENABLED=true
AFTER_HOURS_VOLATILITY=1.5
